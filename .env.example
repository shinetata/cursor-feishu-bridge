# ─── 飞书应用凭证 ──────────────────────────────────────────────────────────────
# 在 open.feishu.cn → 应用详情 → 凭证与基础信息 里获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cursor API Key ────────────────────────────────────────────────────────────
# 在 cursor.com/dashboard/integrations 创建 Personal API Key
CURSOR_API_KEY=cursor_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 可选配置 ──────────────────────────────────────────────────────────────────
# 默认工作区路径（没有 /ws 命令时使用）
DEFAULT_CWD=/Users/your-name/projects/my-project

# Cursor 模型 ID（默认 composer-2.5）
CURSOR_MODEL=composer-2.5

# 日志级别
LOG_LEVEL=info
